{
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
        {
                "src": "/robots.txt",
                "dest": "/robots.txt"
        },
    {
      "src": "/ogp.png",
      "dest": "/ogp.png"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/icon-192.png",
      "dest": "/icon-192.png"
